# .env.example — copy this to .env and fill in your credentials
# Get these from: https://developers.airtel.co.tz/user/signup → Key Management

AIRTEL_CLIENT_ID=your-client-id-here
AIRTEL_CLIENT_SECRET=your-client-secret-here
AIRTEL_SANDBOX=true

# For disbursement only — path to your RSA public key from Key Management
AIRTEL_PUBLIC_KEY_PATH=airtel_pub.pem